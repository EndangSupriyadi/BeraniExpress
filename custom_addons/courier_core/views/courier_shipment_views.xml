<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="courier_shipment_form" model="ir.ui.view">
            <field name="name">courier.shipment.form</field>
            <field name="model">courier.shipment</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1><field name="name" placeholder="No. Resi"/></h1>
                        <group>
                            <field name="customer_id"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="courier_shipment_list" model="ir.ui.view">
            <field name="name">courier.shipment.list</field>
            <field name="model">courier.shipment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="customer_id"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="courier_shipment_action" model="ir.actions.act_window">
            <field name="name">Pengiriman</field>
            <field name="res_model">courier.shipment</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu -->
        <menuitem id="courier_shipment_menu" name="Pengiriman" action="courier_shipment_action" parent="courier_core_menu"/>
    </data>
</odoo>
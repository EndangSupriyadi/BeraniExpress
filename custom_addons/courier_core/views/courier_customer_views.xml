<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <data>
        <!-- Form View -->
        <record id="courier_customer_form" model="ir.ui.view">
            <field name="name">courier.customer.form</field>
            <field name="model">courier.customer</field>
            <field name="arch" type="xml">
                <form>
                    <sheet>
                        <h1><field name="name" placeholder="Nama Pelanggan"/></h1>
                        <group>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <!-- List View -->
        <record id="courier_customer_list" model="ir.ui.view">
            <field name="name">courier.customer.list</field>
            <field name="model">courier.customer</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="email"/>
                    <field name="phone"/>
                </list>
            </field>
        </record>

        <!-- Action -->
        <record id="courier_customer_action" model="ir.actions.act_window">
            <field name="name">Pelanggan</field>
            <field name="res_model">courier.customer</field>
            <field name="view_mode">list,form</field>
        </record>

        <!-- Menu -->
        <menuitem id="courier_customer_menu" name="Pelanggan" action="courier_customer_action" parent="courier_core_menu"/>
    </data>
</odoo>